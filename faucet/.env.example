# ClawChain Testnet Faucet — Environment Variables
#
# Copy to .env and edit before starting:
#   cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Chain Connection ──────────────────────────────────────────────────────────
# WebSocket RPC endpoint of the ClawChain node
RPC_URL=ws://localhost:9944

# ── Faucet Account ───────────────────────────────────────────────────────────
# Seed phrase or dev URI for the faucet account (e.g. //Alice for testnet)
# NEVER commit a real seed phrase — use a dedicated faucet account
FAUCET_SEED=//Alice

# ── Drip Settings ─────────────────────────────────────────────────────────────
# Amount of CLAW (whole tokens) to send per drip  [default: 1000]
DRIP_AMOUNT_CLAW=1000

# Cooldown between drips per address in hours  [default: 24]
COOLDOWN_HOURS=24

# Maximum drip requests per IP per hour  [default: 10]
IP_RATE_LIMIT=10

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Pretty-print logs in development (true/false)
LOG_PRETTY=true
