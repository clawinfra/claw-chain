# ClawChain Validator — Environment Variables
#
# Copy this file to .env in the repo root and edit before starting:
#   cp deploy/.env.example .env
#   nano .env
#   docker compose -f deploy/docker-compose.validator.yml up -d

# ============================================================
# Node Identity
# ============================================================

# Human-readable node name (shown in telemetry and Polkadot.js)
NODE_NAME=ClawChain-Validator

# Docker image version tag (use 'latest' or a specific semver)
CLAWCHAIN_VERSION=latest

# ============================================================
# Chain Configuration
# ============================================================

# Chain spec — one of:
#   dev                              (built-in single-validator dev chain)
#   local                            (built-in two-validator local testnet)
#   /chain-specs/chain.json          (custom spec mounted as a volume)
CHAIN_SPEC=dev

# If using a custom chain spec, set the host path here and uncomment
# the volume mount in docker-compose.validator.yml:
# CHAIN_SPEC_PATH=./specs/clawchain-testnet.json

# ============================================================
# Networking
# ============================================================

# P2P port — must be publicly reachable (open in firewall)
P2P_PORT=30333

# RPC/WebSocket port (bound to 127.0.0.1 by default)
RPC_PORT=9944

# Prometheus metrics port (bound to 127.0.0.1 by default)
METRICS_PORT=9615

# Extra CLI flags (e.g. bootnodes, telemetry URL)
# EXTRA_ARGS=--bootnodes /ip4/1.2.3.4/tcp/30333/p2p/12D3KooW... --telemetry-url 'wss://telemetry.polkadot.io/submit/ 0'
EXTRA_ARGS=

# ============================================================
# Logging
# ============================================================

# Rust log filter — info | warn | error | debug | trace
# Can target specific modules: info,sub-libp2p=warn,grandpa=debug
RUST_LOG=info

# ============================================================
# Grafana (only used with --profile monitoring)
# ============================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-in-production
GRAFANA_ROOT_URL=http://localhost:3000

# ============================================================
# Key Generation (docker-entrypoint.sh)
# ============================================================

# Set to 'true' to auto-generate Aura + GRANDPA session keys on first run
# if the keystore is empty. Keys are logged to stdout — copy them for
# validator registration. Secrets are NOT written to disk.
AUTO_KEY_GEN=false

# ============================================================
# Bootnodes
# ============================================================

# Comma-separated multiaddr bootnode list. Takes precedence over
# TESTNET_BOOTNODE when set.
# Example: BOOTNODES=/ip4/1.2.3.4/tcp/30333/p2p/12D3KooW...
BOOTNODES=

# Pre-configured testnet bootnode (Alice's node on clawchain.win).
# Used automatically when CHAIN_SPEC=local and BOOTNODES is empty.
TESTNET_BOOTNODE=/ip4/135.181.157.121/tcp/30333/p2p/12D3KooWAkZ8Jmv13cdhogi6ESdZ5QVYrVyzosF2oSHMiW8ymZj6
